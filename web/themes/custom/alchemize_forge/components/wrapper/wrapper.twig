{% set _preset = preset|default('none') %}
{% set html_tag = html_tag ?? 'div' %}
{% set width_class = width_class|default('w-100') %}
{% set height_class = height_class|default('none') %}
{% set container_class = container_type != 'none' ? container_type : '' %}

{# Preset class maps — each preset references a single semantic class
   defined in scss/_layout-presets.scss. Design decisions live in SCSS
   (using brand tokens), not as scattered Bootstrap utilities in Twig.
   Individual prop overrides (Bootstrap utilities with !important) reliably
   win over preset classes (normal specificity). #}
{% set preset_classes = {
  'hero-dark':       ['preset-section-hero-dark'],
  'hero-primary':    ['preset-section-hero-primary'],
  'light-section':   ['preset-section-light'],
  'content-section': ['preset-section-content'],
  'cta-banner':      ['preset-section-cta'],
  'feature-strip':   ['preset-section-feature-strip'],
} %}

{# Presets that should force section tag and container #}
{% set preset_section_tags = ['hero-dark', 'hero-primary', 'light-section', 'content-section', 'cta-banner', 'feature-strip'] %}
{% if _preset in preset_section_tags and html_tag == 'div' %}
  {% set html_tag = 'section' %}
{% endif %}
{% if _preset != 'none' and container_class == '' %}
  {% set container_class = 'container' %}
{% endif %}

{% set _preset_list = preset_classes[_preset]|default([]) %}

{% set classes = [
  container_class,
  custom_class,
  shadow is defined and shadow != 'none' ? shadow : '',
  border_radius is defined and border_radius != 'none' ? border_radius : '',
  overflow is defined and overflow != 'none' ? overflow : '',
  width_class != 'none' ? width_class : '',
  height_class != 'none' ? height_class : '',
  margin_for_all,
  margin_top,
  margin_bottom,
  margin_start,
  margin_end,
  margin_x,
  margin_y,
  padding_all,
  padding_top,
  padding_bottom,
  padding_start,
  padding_end,
  padding_x,
  padding_y,
] %}

{% if flex_enabled %}
  {% set flex_classes = [
    'd-flex',
    flex_direction,
    flex_gap != 'none' ? flex_gap : '',
    flex_width != 'none' ? flex_width : '',
    justify_content != 'none' ? justify_content : '',
    align_items != 'none' ? align_items : '',
  ] %}
  {% set classes = classes|merge(flex_classes) %}
{% endif %}

{% set classes = classes|merge(_preset_list) %}

<{{ html_tag }}{{ attributes.addClass(classes|filter(v => v)) }}>
  {% block content %}{% endblock %}
</{{ html_tag }}>
