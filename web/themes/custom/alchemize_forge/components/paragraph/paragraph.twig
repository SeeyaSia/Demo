{% set _preset = preset|default('none') %}
{% set text_color = text_color|default('none') %}
{% set text_rendered = text is iterable ? text|render : text|default('') %}
{% set text_stripped = text_rendered|striptags|trim %}

{% if text_stripped is not empty %}
  {# --- Normal rendering: text has actual content --- #}
  {% set text_markup = text_rendered|lower %}
  {% set has_block_tags = text_markup matches '/<\\s*(p|div|ul|ol|blockquote)\\b/' %}
  {% set wrapper_tag = has_block_tags ? 'div' : 'p' %}

  {# Preset class maps — each preset references a single typography role class
     defined in scss/_typography-roles.scss. Sizes and weights come from the
     brand type scale ($type-scale in _typography.scss), not Bootstrap defaults. #}
  {% set preset_classes = {
    'lead':       ['role-text-lead'],
    'caption':    ['role-text-caption'],
    'fine-print': ['role-text-fine-print'],
  } %}

  {% set _preset_list = preset_classes[_preset]|default([]) %}

  {% set classes = [
      'paragraph',
      is_lead is defined and is_lead ? 'lead' : '',
      font_weight is defined and font_weight != 'none' ? font_weight : '',
      font_size is defined and font_size != 'none' ? font_size : '',
      text_color != 'none' ? text_color : '',
      margin_all,
      margin_top,
      margin_bottom,
      margin_start,
      margin_end,
      margin_x,
      margin_y,
      padding_all,
      padding_top,
      padding_bottom,
      padding_start,
      padding_end,
      padding_x,
      padding_y,
  ]|merge(_preset_list) %}

  <{{ wrapper_tag }}{{ attributes.addClass(classes) }}>
    {{ text_rendered }}
  </{{ wrapper_tag }}>
{% endif %}
